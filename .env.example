# --- Telegram ---
# Get from @BotFather on Telegram (/newbot)
HM_TELEGRAM_BOT_TOKEN=

# Comma-separated allowlist of chat IDs that can interact with the bot.
# Find your chat_id by messaging the bot, then:
#   curl "https://api.telegram.org/bot<TOKEN>/getUpdates" | jq '.result[].message.from.id'
HM_TELEGRAM_CHAT_IDS=

# Optional. Chat that receives "unauthorized user tried to access" notifications.
# Defaults to the first ID in HM_TELEGRAM_CHAT_IDS.
HM_TELEGRAM_ADMIN_CHAT_ID=

# --- Scheduling ---
# 6-field cron (second minute hour dom month dow). Default = every Sunday 06:00.
HM_SCHEDULE=0 0 6 * * 0

# --- Containers to watch ---
# Comma-separated container names. Leave empty to watch all running containers (except self).
HM_WATCH=

# Per-container changelog override (optional). Format: HM_CHANGELOG_<container>=<source>
# Sources: github:owner/repo  |  servarr:<branch>  |  none
# HM_CHANGELOG_sonarr=servarr:main
# HM_CHANGELOG_prowlarr=servarr:master

# --- External APIs ---
# Optional. Raises GitHub API rate limit (60/hr → 5000/hr).
HM_GITHUB_TOKEN=

# --- Web dashboard auth ---
# Required if exposing beyond LAN. Any long random string.
# If unset, the dashboard is publicly accessible (warning logged at startup).
HM_WEB_AUTH_TOKEN=

# --- Misc ---
TZ=Europe/Bucharest
LOG_LEVEL=info
